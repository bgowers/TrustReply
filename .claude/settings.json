{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(./.env)",
      "Read(.env.local)",
      "Read(./.env.local)",
      "Read(.env.development)",
      "Read(./.env.development)",
      "Read(.env.development.local)",
      "Read(./.env.development.local)",
      "Read(.env.production)",
      "Read(./.env.production)",
      "Read(.env.production.local)",
      "Read(./.env.production.local)",
      "Read(.env.test)",
      "Read(./.env.test)",
      "Read(.env.test.local)",
      "Read(./.env.test.local)",
      "Read(.env.staging)",
      "Read(./.env.staging)",
      "Read(.env.preview)",
      "Read(./.env.preview)",
      "Read(.env.vault)",
      "Read(./.env.vault)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.development.local)",
      "Read(**/.env.production)",
      "Read(**/.env.production.local)",
      "Read(**/.env.test)",
      "Read(**/.env.test.local)",
      "Read(**/.env.staging)",
      "Read(**/.env.preview)",
      "Read(**/.env.vault)",
      "Bash(cat .env*)",
      "Bash(cat ./.env*)",
      "Bash(head .env*)",
      "Bash(head ./.env*)",
      "Bash(tail .env*)",
      "Bash(tail ./.env*)",
      "Bash(less .env*)",
      "Bash(less ./.env*)",
      "Bash(more .env*)",
      "Bash(more ./.env*)",
      "Bash(bat .env*)",
      "Bash(bat ./.env*)",
      "Bash(xxd .env*)",
      "Bash(od .env*)",
      "Bash(strings .env*)"
    ]
  }
}
