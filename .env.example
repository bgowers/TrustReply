# Anthropic
ANTHROPIC_API_KEY=

# Supabase (new key model — sb_publishable_… and sb_secret_…)
# Local dev: run `supabase start` and copy the printed values here.
# The API URL is typically http://127.0.0.1:54321 for the local stack.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_SOLO=
NEXT_PUBLIC_STRIPE_PRICE_TEAM=

# Resend (optional — Supabase default email works for dev)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
